{
  "name": "infinarena-backend",
  "version": "2.0.0",
  "private": true,
  "description": "infinArena backend",
  "scripts": {
    "dev": "pnpm run dev:all",
    "dev:all": "tsx watch src/server.ts",
    "dev:admin": "tsx watch src/server-admin.ts",
    "dev:player": "tsx watch src/server-player.ts",
    "start": "pnpm run start:all",
    "start:all": "tsx src/server.ts",
    "start:admin": "tsx src/server-admin.ts",
    "start:player": "tsx src/server-player.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:seed": "tsx src/lib/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/lib-storage": "^3.1001.0",
    "@libsql/client": "^0.14.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "drizzle-orm": "^0.36.4",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "ioredis": "^5.10.0",
    "multer": "^1.4.5-lts.2",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
