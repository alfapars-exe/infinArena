{
  "name": "kahoot-workspace",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:frontend:admin": "pnpm --dir frontend dev:admin",
    "dev:frontend:player": "pnpm --dir frontend dev:player",
    "dev:backend": "pnpm --dir backend dev",
    "dev:backend:admin": "pnpm --dir backend dev:admin",
    "dev:backend:player": "pnpm --dir backend dev:player",
    "build": "pnpm --dir backend build && pnpm --dir frontend build",
    "typecheck": "pnpm --dir backend typecheck && pnpm --dir frontend typecheck",
    "lint": "pnpm --dir backend lint && pnpm --dir frontend lint",
    "test": "pnpm --dir backend test",
    "l10n:check": "node scripts/l10n-check.mjs"
  }
}
